rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Instrument photos: instruments/{instrumentId}/photo
    match /instruments/{instrumentId}/photo {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size <= 800 * 1024   // 800 KB max (enforced server-side as well)
        && request.resource.contentType.matches('image/.*');
    }

    // Maintenance damage photos: maintenance/{maintenanceId}/damage-photos/{filename}
    match /maintenance/{maintenanceId}/damage-photos/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size <= 800 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
