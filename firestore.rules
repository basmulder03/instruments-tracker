rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userPermissions() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions;
    }

    // Checks for exact match, resource wildcard, action wildcard, or superadmin
    function hasPermission(resource, action) {
      return (resource + ':' + action) in userPermissions()
          || (resource + ':*')        in userPermissions()
          || ('*:' + action)          in userPermissions()
          || '*:*'                    in userPermissions();
    }

    function isAdmin() {
      return '*:*' in userPermissions();
    }

    // Users collection
    match /users/{userId} {
      allow read:   if isAuthenticated() && (request.auth.uid == userId || hasPermission('users', 'read'));
      allow create: if isAuthenticated() && hasPermission('users', 'create');
      allow update: if isAuthenticated() && (request.auth.uid == userId || hasPermission('users', 'update'));
      allow delete: if isAuthenticated() && hasPermission('users', 'delete');
    }

    // Roles collection
    match /roles/{roleId} {
      allow read:   if isAuthenticated() && hasPermission('roles', 'read');
      allow create: if isAuthenticated() && hasPermission('roles', 'create');
      allow update: if isAuthenticated() && hasPermission('roles', 'update');
      allow delete: if isAuthenticated() && hasPermission('roles', 'delete');
    }

    // Permissions collection
    match /permissions/{permissionId} {
      allow read:   if isAuthenticated() && hasPermission('permissions', 'read');
      allow create: if isAuthenticated() && hasPermission('permissions', 'create');
      allow update: if isAuthenticated() && hasPermission('permissions', 'update');
      allow delete: if isAuthenticated() && hasPermission('permissions', 'delete');
    }

    // Invitations collection
    // Unauthenticated reads are needed so a prospective user can verify their token
    match /invitations/{invitationId} {
      allow read:   if resource.data.token == request.query.token
                    || (isAuthenticated() && hasPermission('invitations', 'read'));
      allow create: if isAuthenticated() && hasPermission('invitations', 'create');
      allow update: if isAuthenticated() && hasPermission('invitations', 'update');
      allow delete: if isAuthenticated() && hasPermission('invitations', 'delete');
    }

    // Instruments collection
    match /instruments/{instrumentId} {
      allow read:   if isAuthenticated() && hasPermission('instruments', 'read');
      allow create: if isAuthenticated() && hasPermission('instruments', 'create');
      allow update: if isAuthenticated() && hasPermission('instruments', 'update');
      allow delete: if isAuthenticated() && hasPermission('instruments', 'delete');
    }

    // People collection
    match /people/{personId} {
      allow read:   if isAuthenticated() && hasPermission('people', 'read');
      allow create: if isAuthenticated() && hasPermission('people', 'create');
      allow update: if isAuthenticated() && hasPermission('people', 'update');
      allow delete: if isAuthenticated() && hasPermission('people', 'delete');
    }

    // Locations collection
    match /locations/{locationId} {
      allow read:   if isAuthenticated() && hasPermission('locations', 'read');
      allow create: if isAuthenticated() && hasPermission('locations', 'create');
      allow update: if isAuthenticated() && hasPermission('locations', 'update');
      allow delete: if isAuthenticated() && hasPermission('locations', 'delete');
    }

    // Movements collection
    match /movements/{movementId} {
      allow read:   if isAuthenticated() && hasPermission('movements', 'read');
      allow create: if isAuthenticated() && hasPermission('movements', 'create');
      allow update: if isAuthenticated() && hasPermission('movements', 'update');
      allow delete: if isAuthenticated() && hasPermission('movements', 'delete');
    }

    // Maintenance collection
    match /maintenance/{maintenanceId} {
      allow read:   if isAuthenticated() && hasPermission('maintenance', 'read');
      allow create: if isAuthenticated() && hasPermission('maintenance', 'create');
      allow update: if isAuthenticated() && hasPermission('maintenance', 'update');
      allow delete: if isAuthenticated() && hasPermission('maintenance', 'delete');
    }

    // Usage events collection
    match /usage_events/{usageEventId} {
      allow read:   if isAuthenticated() && hasPermission('usage', 'read');
      allow create: if isAuthenticated() && hasPermission('usage', 'create');
      allow update: if isAuthenticated() && hasPermission('usage', 'update');
      allow delete: if isAuthenticated() && hasPermission('usage', 'delete');
    }

    // Analytics derived collections (read: analytics:view, write: analytics:rebuild)
    match /usage_stats/{usageStatId} {
      allow read:  if isAuthenticated() && hasPermission('analytics', 'view');
      allow write: if isAuthenticated() && hasPermission('analytics', 'rebuild');
    }

    match /maintenance_predictions/{predictionId} {
      allow read:  if isAuthenticated() && hasPermission('analytics', 'view');
      allow write: if isAuthenticated() && hasPermission('analytics', 'rebuild');
    }

    match /depreciation/{depreciationId} {
      allow read:  if isAuthenticated() && hasPermission('analytics', 'view');
      allow write: if isAuthenticated() && hasPermission('analytics', 'rebuild');
    }

    // Audit log — append-only; updates and deletes are permanently forbidden
    match /audit_log/{auditId} {
      allow read:          if isAuthenticated() && hasPermission('audit', 'view');
      allow create:        if isAuthenticated();
      allow update, delete: if false;
    }

    // ID counters collection (used by idGenerator.ts) — authenticated writes only
    match /id_counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
