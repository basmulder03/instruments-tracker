rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Only call this when request.auth != null AND the user doc is known to exist
    function userPermissions() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions;
    }

    // Safe wrapper: returns false immediately if not authenticated,
    // avoiding the get() call for unauthenticated requests.
    function hasPermission(resource, action) {
      return isAuthenticated()
          && (
               (resource + ':' + action) in userPermissions()
            || (resource + ':*')          in userPermissions()
            || ('*:' + action)            in userPermissions()
            || '*:*'                      in userPermissions()
             );
    }

    // Users collection
    // A user can always read/update their own document (needed on first login
    // before any permission doc is loaded). All other operations require a
    // permission check via hasPermission.
    match /users/{userId} {
      allow read:   if isAuthenticated()
                    && (request.auth.uid == userId || hasPermission('users', 'read'));
      allow create: if hasPermission('users', 'create');
      allow update: if isAuthenticated()
                    && (request.auth.uid == userId || hasPermission('users', 'update'));
      allow delete: if hasPermission('users', 'delete');
    }

    // Roles collection
    match /roles/{roleId} {
      allow read:   if hasPermission('roles', 'read');
      allow create: if hasPermission('roles', 'create');
      allow update: if hasPermission('roles', 'update');
      allow delete: if hasPermission('roles', 'delete');
    }

    // Permissions collection
    match /permissions/{permissionId} {
      allow read:   if hasPermission('permissions', 'read');
      allow create: if hasPermission('permissions', 'create');
      allow update: if hasPermission('permissions', 'update');
      allow delete: if hasPermission('permissions', 'delete');
    }

    // Invitations collection
    // acceptInvitation() queries by token before the user is authenticated,
    // so allow a document read when the stored token matches the queried token.
    match /invitations/{invitationId} {
      allow read:   if (isAuthenticated() && hasPermission('invitations', 'read'))
                    || resource.data.token == request.resource.data.token;
      allow create: if hasPermission('invitations', 'create');
      allow update: if hasPermission('invitations', 'update')
                    || (isAuthenticated()
                        && resource.data.token != null
                        && request.resource.data.status in ['accepted', 'expired']);
      allow delete: if hasPermission('invitations', 'delete');
    }

    // Instruments collection
    match /instruments/{instrumentId} {
      allow read:   if hasPermission('instruments', 'read');
      allow create: if hasPermission('instruments', 'create');
      allow update: if hasPermission('instruments', 'update');
      allow delete: if hasPermission('instruments', 'delete');
    }

    // People collection
    match /people/{personId} {
      allow read:   if hasPermission('people', 'read');
      allow create: if hasPermission('people', 'create');
      allow update: if hasPermission('people', 'update');
      allow delete: if hasPermission('people', 'delete');
    }

    // Locations collection
    match /locations/{locationId} {
      allow read:   if hasPermission('locations', 'read');
      allow create: if hasPermission('locations', 'create');
      allow update: if hasPermission('locations', 'update');
      allow delete: if hasPermission('locations', 'delete');
    }

    // Movements collection
    match /movements/{movementId} {
      allow read:   if hasPermission('movements', 'read');
      allow create: if hasPermission('movements', 'create');
      allow update: if hasPermission('movements', 'update');
      allow delete: if hasPermission('movements', 'delete');
    }

    // Maintenance collection
    match /maintenance/{maintenanceId} {
      allow read:   if hasPermission('maintenance', 'read');
      allow create: if hasPermission('maintenance', 'create');
      allow update: if hasPermission('maintenance', 'update');
      allow delete: if hasPermission('maintenance', 'delete');
    }

    // Usage events collection
    match /usage_events/{usageEventId} {
      allow read:   if hasPermission('usage', 'read');
      allow create: if hasPermission('usage', 'create');
      allow update: if hasPermission('usage', 'update');
      allow delete: if hasPermission('usage', 'delete');
    }

    // Analytics derived collections
    match /usage_stats/{usageStatId} {
      allow read:  if hasPermission('analytics', 'view');
      allow write: if hasPermission('analytics', 'rebuild');
    }

    match /maintenance_predictions/{predictionId} {
      allow read:  if hasPermission('analytics', 'view');
      allow write: if hasPermission('analytics', 'rebuild');
    }

    match /depreciation/{depreciationId} {
      allow read:  if hasPermission('analytics', 'view');
      allow write: if hasPermission('analytics', 'rebuild');
    }

    // Audit log — append-only
    match /audit_log/{auditId} {
      allow read:           if hasPermission('audit', 'view');
      allow create:         if isAuthenticated();
      allow update, delete: if false;
    }

    // ID counters used by idGenerator.ts
    match /id_counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
